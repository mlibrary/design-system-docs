                <ul class="card-links">
                  <li><a href="/visual-elements/logo/"><span class="material-symbols-rounded visual-elements" aria-hidden="true">design_services</span>
                   <span>Library logos</span></a>
                  </li>
                   <li>
                    <a href="/visual-elements/template-theme/"> <span class="material-symbols-rounded visual-elements" aria-hidden="true">folder</span>
                    <span>Templates and themes</span></a>
                  </li>
                </ul>
