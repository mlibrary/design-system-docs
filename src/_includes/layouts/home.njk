                  <li><a href="/visual-elements/color/">
                    <span class="material-symbols-rounded visual-elements" aria-hidden="true">palette</span><span>Color</span></a></li>
                  <li><a href="https://www.figma.com/@mlibrary">
                    <span class="material-symbols-rounded visual-elements" aria-hidden="true">design_services</span><span>Figma toolkit</span></a></li>
                  <li><a href="/visual-elements/icons/"><span class="material-symbols-rounded visual-elements" aria-hidden="true">design_services</span><span>Icons</span></a></li>
                </ul>
              </section>
              <section class="card">
                <h2>Develop User Interfaces</h2>
                <p>Use specifications, copy and paste HTML and CSS, or web components and design tokens.</p>
                 <ul class="card-links">
                  <li><a href="/develop/build-user-interfaces/"><span class="material-symbols-rounded develop" aria-hidden="true">code</span><span>Build user interfaces</span></a></li>
                  <li><a href="/develop/design-tokens-and-web-components/"><span class="material-symbols-rounded develop" aria-hidden="true">code</span><span>Design tokens</span></a></li>
                </ul>
