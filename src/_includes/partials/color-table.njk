{% for group in colorTokens %}
<h3>{{ group.family }}</h3>
<table class="color-token-table">
  <thead>
    <tr>
      <th scope="col">Swatch</th>
      <th scope="col">Hex Code</th>
      <th scope="col">Token</th>
      <th scope="col">Use Case(s)</th>
    </tr>
  </thead>
  <tbody>
    {% for c in group.colors %}
    <tr>
      <td>
        <span class="color-swatch" style="background-color: {{ c.hex }};" aria-hidden="true"></span>
      </td>
     <td><code>{{ c.hex }}</code><button class="copy-btn material-symbols-rounded" data-copy-value="{{ c.hex }}" aria-label="Copy hex code {{ c.hex }}">content_copy</button></td>
      <td>
        {% for t in c.token %}
        <code>{{ t }}</code>{% if not loop.last %}<br>{% endif %}
        {% endfor %}
      </td>
      <td>{{ c.useCase }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endfor %}

<div class="visually-hidden" role="status" aria-live="polite" id="copy-status"></div>